{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "none",
	"printWidth": 100,
	"svelte": true,
	"sortTailwindcss": {
		"stylesheet": "./src/routes/layout.css"
	},
	"ignorePatterns": [
		"static/**",
		"pnpm-lock.yaml",
		"package-lock.json",
		"yarn.lock",
		"bun.lock",
		"bun.lockb",
		"worker-configuration.d.ts"
	]
}
